# ── App
APP_NAME="PPT Intelligent Generation System"
APP_VERSION="0.1.0"
DEBUG=true
ALLOWED_ORIGINS='["http://localhost:5173","http://localhost:3000"]'

# ── 数据库
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ppt_system
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TASK_DB=1
REDIS_CACHE_TTL=3600

# ── Auth / JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OSS
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET_NAME=ppt-files
OSS_REGION=us-east-1

# ── LLM
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_STREAM_TIMEOUT=120

# ── Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1536

# ── RAG (pgvector)
PGVECTOR_URL=postgresql+asyncpg://postgres:password@localhost:5432/ppt_system
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.75
RAG_TIMEOUT_SECONDS=5

# ── DeepSearch
SEARCH_PROVIDER=tavily
SEARCH_API_KEY=tvly-your-key-here
SEARCH_MAX_RESULTS=10
SEARCH_TIMEOUT_SECONDS=15

# ── Task
TASK_CHUNK_TTL=3600
TASK_MAX_RETRIES=3
TASK_RETRY_DELAY=5

# ── File Processing
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS='["pdf","docx","md","txt"]'
