# Copy to backend/.env and replace every CHANGE_ME value before production use.
# Do not commit backend/.env.

# Application
APP_NAME=PPT Intelligent Generation System
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=["https://ppt.vestigor.top"]

# PostgreSQL container and application connection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
POSTGRES_DB=ppt_system
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_DATABASE_PASSWORD@postgres:5432/ppt_system
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0
REDIS_ENCODING=utf-8
REDIS_DECODE_RESPONSES=true
REDIS_MAX_CONNECTIONS=50
REDIS_HEALTH_CHECK_INTERVAL=30

# JWT and encryption. Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD
OSS_ENDPOINT=http://minio:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=CHANGE_ME_STRONG_MINIO_PASSWORD
OSS_BUCKET_NAME=ppt-files
OSS_REGION=us-east-1
OSS_MAX_POOL_CONNECTIONS=50
OSS_MAX_ATTEMPTS=3

# LLM defaults
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_STREAM_TIMEOUT=120

# Embedding / RAG
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
DASHSCOPE_API_KEY=CHANGE_ME_DASHSCOPE_API_KEY
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Web search
SEARCH_MAX_RESULTS=10

# Uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=["pdf","docx","md","txt"]

# SMTP email verification and password reset
SMTP_HOST=smtp.yeah.net
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=CHANGE_ME_SMTP_USERNAME
SMTP_PASSWORD=CHANGE_ME_SMTP_APP_PASSWORD
EMAIL_FROM_NAME=PPT 智能生成系统
EMAIL_CODE_TTL_SECONDS=600

# Password policy and middleware
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=16
SLOW_REQUEST_THRESHOLD_MS=2000
GZIP_MINIMUM_SIZE=1024
