                        "\u4e91\u8ba1\u7b97\u5e73\u53f0\u964d\u4f4e\u4e86\u4e2d\u5c0f\u4f01\u4e1a\u4f7f\u7528\u9ad8\u6027\u80fd\u7b97\u529b\u7684\u95e8\u69db\u4e0e\u90e8\u7f72\u6210\u672c\u3002",
                        "\u80fd\u8017\u6bd4\u6210\u4e3a\u8861\u91cf\u65b0\u4e00\u4ee3\u4eba\u5de5\u667a\u80fd\u786c\u4ef6\u7684\u91cd\u8981\u6307\u6807\u4e4b\u4e00\u4e0e\u73af\u4fdd\u8981\u6c42\u3002"
                    ]
                }
            ],
            "speaker_notes": "\u6ca1\u6709\u5f3a\u5927\u7684\u7b97\u529b\u652f\u6491\uff0c\u590d\u6742\u7684\u6df1\u5ea6\u5b66\u4e60\u6a21\u578b\u6839\u672c\u65e0\u6cd5\u5728\u5408\u7406\u65f6\u95f4\u5185\u5b8c\u6210\u8bad\u7ec3\u3002"
        },
        {
