        {
            "slide_number": 13,
            "slide_type": "content",
            "title": "\u6570\u636e\u8981\u7d20\u7684\u91cd\u8981\u6027",
            "chapter_title": "\u7b2c\u4e09\u7ae0\uff1a\u6838\u5fc3\u9a71\u52a8\u529b\u89e3\u6790",
            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4e92\u8054\u7f51\u4ea7\u751f\u7684\u6d77\u91cf\u6570\u636e\u4e3a\u6a21\u578b\u8bad\u7ec3\u63d0\u4f9b\u4e86\u5145\u8db3\u71c3\u6599\uff0c\u5927\u6570\u636e\u7684\u6218\u7565\u610f\u4e49\u5728\u4e8e\u63d0\u5347\u5904\u7406\u80fd\u529b\u4ee5\u5b9e\u73b0\u6570\u636e\u589e\u503c\u3002\u9ad8\u8d28\u91cf\u7684\u6570\u636e\u6807\u6ce8\u76f4\u63a5\u51b3\u5b9a\u4e86\u76d1\u7763\u5b66\u4e60\u6a21\u578b\u7684\u6700\u7ec8\u6027\u80fd\u8868\u73b0\uff0c\u662f\u7b97\u6cd5\u843d\u5730\u7684\u57fa\u77f3\u3002"
                },
                {
                    "type": "bullet_list",
                    "items": [
                        "\u4e92\u8054\u7f51\u4ea7\u751f\u7684\u6d77\u91cf\u6570\u636e\u4e3a\u6a21\u578b\u8bad\u7ec3\u63d0\u4f9b\u4e86\u5145\u8db3\u71c3\u6599\u4e0e\u57fa\u7840\u8d44\u6e90\u3002",
                        "\u6570\u636e\u6807\u6ce8\u8d28\u91cf\u76f4\u63a5\u5f71\u54cd\u76d1\u7763\u5b66\u4e60\u6a21\u578b\u7684\u6700\u7ec8\u6027\u80fd\u8868\u73b0\u4e0e\u6cdb\u5316\u80fd\u529b\u3002",
                        "\u9690\u79c1\u4fdd\u62a4\u6cd5\u89c4\u4fc3\u4f7f\u5408\u6210\u6570\u636e\u6280\u672f\u5728\u8bad\u7ec3\u4e2d\u7684\u5e94\u7528\u589e\u957f\u4ee5\u5408\u89c4\u4f7f\u7528\u3002"
                    ]
                }
            ],
            "speaker_notes": "\u5927\u6570\u636e\u5177\u6709\u6570\u91cf\u3001\u9ad8\u901f\u3001\u591a\u6837\u7b49\u7279\u5f81\uff0c\u5173\u952e\u5728\u4e8e\u901a\u8fc7\u5904\u7406\u5b9e\u73b0\u4ef7\u503c\u589e\u503c\uff0c\u800c\u975e\u5355\u7eaf\u638c\u63e1\u4fe1\u606f\u3002\uff08\u6765\u6e90\uff1a\u4eba\u5de5\u667a\u80fd\u53f2.pdf\uff09"
        },
        {
            "slide_number": 14,
            "slide_type": "content",
            "title": "\u7b97\u6cd5\u67b6\u6784\u7684\u6f14\u8fdb",
            "chapter_title": "\u7b2c\u4e09\u7ae0\uff1a\u6838\u5fc3\u9a71\u52a8\u529b\u89e3\u6790",
            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4ece\u5377\u79ef\u795e\u7ecf\u7f51\u7edc\u4e13\u95e8\u4f18\u5316\u56fe\u50cf\u7a7a\u95f4\u7279\u5f81\uff0c\u5230\u5faa\u73af\u795e\u7ecf\u7f51\u7edc\u4e3b\u5bfc\u5e8f\u5217\u6570\u636e\uff0c\u518d\u5230\u8fc1\u79fb\u5b66\u4e60\u7684\u5e7f\u6cdb\u5e94\u7528\uff0c\u7b97\u6cd5\u67b6\u6784\u4e0d\u65ad\u9002\u5e94\u4e0d\u540c\u573a\u666f\u3002\u8fd9\u79cd\u6f14\u8fdb\u8ba9\u6a21\u578b\u80fd\u591f\u5229\u7528\u5df2\u6709\u77e5\u8bc6\u89e3\u51b3\u65b0\u9886\u57df\u95ee\u9898\uff0c\u6781\u5927\u5730\u63d0\u9ad8\u4e86\u5f00\u53d1\u6548\u7387\u3002"
                },
                {
                    "type": "bullet_list",
                    "items": [
                        "\u5377\u79ef\u795e\u7ecf\u7f51\u7edc\u4e13\u95e8\u4f18\u5316\u4e86\u56fe\u50cf\u7a7a\u95f4\u7279\u5f81\u7684\u63d0\u53d6\u6548\u7387\u4e0e\u8bc6\u522b\u7cbe\u5ea6\u3002",
                        "\u5faa\u73af\u795e\u7ecf\u7f51\u7edc\u66fe\u4e3b\u5bfc\u5e8f\u5217\u6570\u636e\u5904\u7406\u4f46\u9010\u6e10\u88ab Transformer \u67b6\u6784\u66ff\u4ee3\u3002",
                        "\u8fc1\u79fb\u5b66\u4e60\u8ba9\u6a21\u578b\u80fd\u591f\u5229\u7528\u5df2\u6709\u77e5\u8bc6\u89e3\u51b3\u65b0\u9886\u57df\u95ee\u9898\u5e76\u51cf\u5c11\u6570\u636e\u91cf\u3002"
                    ]
                }
            ],
            "speaker_notes": "\u7b97\u6cd5\u7684\u6bcf\u4e00\u6b21\u8fed\u4ee3\u90fd\u662f\u4e3a\u4e86\u66f4\u597d\u5730\u6a21\u62df\u4eba\u7c7b\u8ba4\u77e5\u8fc7\u7a0b\uff0c\u540c\u65f6\u517c\u987e\u8ba1\u7b97\u8d44\u6e90\u7684\u9650\u5236\u3002"
        },
        {
            "slide_number": 15,
            "slide_type": "content",
            "title": "\u7b97\u529b\u57fa\u7840\u8bbe\u65bd\u5347\u7ea7",
            "chapter_title": "\u7b2c\u4e09\u7ae0\uff1a\u6838\u5fc3\u9a71\u52a8\u529b\u89e3\u6790",
            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4e13\u7528\u82af\u7247\u5982 TPU \u9488\u5bf9\u77e9\u9635\u8fd0\u7b97\u8fdb\u884c\u4e86\u786c\u4ef6\u7ea7\u4f18\u5316\uff0c\u4e91\u8ba1\u7b97\u5e73\u53f0\u964d\u4f4e\u4e86\u4e2d\u5c0f\u4f01\u4e1a\u4f7f\u7528\u9ad8\u6027\u80fd\u7b97\u529b\u7684\u95e8\u69db\u3002\u80fd\u8017\u6bd4\u6210\u4e3a\u8861\u91cf\u65b0\u4e00\u4ee3\u4eba\u5de5\u667a\u80fd\u786c\u4ef6\u7684\u91cd\u8981\u6307\u6807\u4e4b\u4e00\uff0c\u7eff\u8272\u8ba1\u7b97\u5c06\u6210\u4e3a\u672a\u6765\u7684\u91cd\u8981\u53d1\u5c55\u65b9\u5411\u3002"
                },
                {
                    "type": "bullet_list",
                    "items": [
