        {
            "slide_number": 8,
            "slide_type": "content",
            "title": "\u6df1\u5ea6\u5b66\u4e60\u6280\u672f\u7a81\u7834",
            "chapter_title": "\u7b2c\u4e8c\u7ae0\uff1a\u5173\u952e\u8f6c\u6298\u4e0e\u91cc\u7a0b\u7891",
            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4e8c\u96f6\u96f6\u516d\u5e74\u6df1\u5ea6\u7f6e\u4fe1\u7f51\u7edc\u7684\u63d0\u51fa\u5f00\u542f\u4e86\u6df1\u5ea6\u5b66\u4e60\u7684\u65b0\u7eaa\u5143\uff0c\u968f\u540e\u5377\u79ef\u795e\u7ecf\u7f51\u7edc\u5728\u56fe\u50cf\u8bc6\u522b\u4efb\u52a1\u4e0a\u53d6\u5f97\u4e86\u7a81\u7834\u6027\u8fdb\u5c55\u3002GPU \u5e76\u884c\u8ba1\u7b97\u80fd\u529b\u7684\u63d0\u5347\u89e3\u51b3\u4e86\u6df1\u5c42\u6a21\u578b\u8bad\u7ec3\u8017\u65f6\u8fc7\u957f\u7684\u95ee\u9898\uff0c\u4f7f\u5f97\u5927\u89c4\u6a21\u53c2\u6570\u4f18\u5316\u6210\u4e3a\u53ef\u80fd\u3002"
                },
                {
                    "type": "bullet_list",
                    "items": [
                        "\u4e8c\u96f6\u96f6\u516d\u5e74\u6df1\u5ea6\u7f6e\u4fe1\u7f51\u7edc\u5f00\u542f\u4e86\u6df1\u5ea6\u5b66\u4e60\u7684\u65b0\u7eaa\u5143\u5e76\u5960\u5b9a\u7406\u8bba\u57fa\u7840\u3002",
                        "\u4e8c\u96f6\u4e00\u4e8c\u5e74 AlexNet \u5728\u56fe\u50cf\u8bc6\u522b\u7ade\u8d5b\u4e2d\u5927\u5e45\u964d\u4f4e\u8bef\u5dee\u7387\u5f15\u53d1\u5173\u6ce8\u3002",
                        "GPU \u5e76\u884c\u8ba1\u7b97\u80fd\u529b\u6210\u4e3a\u8bad\u7ec3\u6df1\u5c42\u6a21\u578b\u7684\u5173\u952e\u52a0\u901f\u5668\u4e0e\u786c\u4ef6\u652f\u6491\u3002"
                    ]
                }
            ],
            "speaker_notes": "\u8fd9\u4e00\u9636\u6bb5\u7684\u6280\u672f\u79ef\u7d2f\u4e3a\u540e\u7eed\u7684\u89c6\u89c9\u8bc6\u522b\u548c\u8bed\u97f3\u5904\u7406\u5e94\u7528\u6253\u4e0b\u4e86\u575a\u5b9e\u7684\u7b97\u6cd5\u57fa\u7840\u3002"
        },
        {
            "slide_number": 9,
            "slide_type": "content",
            "title": "\u5f3a\u5316\u5b66\u4e60\u4e0e\u535a\u5f08\u80dc\u5229",
            "chapter_title": "\u7b2c\u4e8c\u7ae0\uff1a\u5173\u952e\u8f6c\u6298\u4e0e\u91cc\u7a0b\u7891",
            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4e8c\u96f6\u4e00\u516d\u5e74 AlphaGo \u6218\u80dc\u674e\u4e16\u77f3\u6807\u5fd7\u5f3a\u5316\u5b66\u4e60\u91cd\u5927\u7a81\u7834\uff0c\u5c55\u793a\u4e86\u673a\u5668\u5728\u590d\u6742\u51b3\u7b56\u573a\u666f\u4e0b\u8d85\u8d8a\u4eba\u7c7b\u7684\u80fd\u529b\u3002\u8499\u7279\u5361\u6d1b\u6811\u641c\u7d22\u4e0e\u7b56\u7565\u4ef7\u503c\u7f51\u7edc\u7684\u7ed3\u5408\u663e\u8457\u63d0\u5347\u4e86\u51b3\u7b56\u6548\u7387\uff0c\u8be5\u4e8b\u4ef6\u5f15\u53d1\u4e86\u5168\u7403\u516c\u4f17\u5bf9\u4eba\u5de5\u667a\u80fd\u6f5c\u529b\u7684\u5e7f\u6cdb\u5173\u6ce8\u70ed\u6f6e\u3002"
                },
                {
                    "type": "bullet_list",
                    "items": [
                        "\u4e8c\u96f6\u4e00\u516d\u5e74 AlphaGo \u6218\u80dc\u674e\u4e16\u77f3\u6807\u5fd7\u5f3a\u5316\u5b66\u4e60\u91cd\u5927\u7a81\u7834\u4e0e\u91cc\u7a0b\u7891\u3002",
                        "\u8499\u7279\u5361\u6d1b\u6811\u641c\u7d22\u4e0e\u7b56\u7565\u4ef7\u503c\u7f51\u7edc\u7ed3\u5408\u63d0\u5347\u51b3\u7b56\u6548\u7387\u4e0e\u80dc\u7387\u3002",
                        "\u8be5\u4e8b\u4ef6\u5f15\u53d1\u5168\u7403\u516c\u4f17\u5bf9\u4eba\u5de5\u667a\u80fd\u6f5c\u529b\u7684\u5e7f\u6cdb\u5173\u6ce8\u70ed\u6f6e\u4e0e\u8ba8\u8bba\u3002"
                    ]
                }
            ],
            "speaker_notes": "AlphaGo \u7684\u80dc\u5229\u4e0d\u4ec5\u662f\u56f4\u68cb\u754c\u7684\u9707\u52a8\uff0c\u66f4\u662f AI \u4ece\u7279\u5b9a\u4efb\u52a1\u5411\u901a\u7528\u51b3\u7b56\u8fc8\u8fdb\u7684\u91cd\u8981\u4fe1\u53f7\u3002\uff08\u6765\u6e90\uff1a\u4eba\u5de5\u667a\u80fd\u53f2.pdf\uff09"
        },
        {
            "slide_number": 10,
            "slide_type": "content",
            "title": "\u81ea\u7136\u8bed\u8a00\u5904\u7406\u53d8\u9769",
