            "speaker_notes": "\u9762\u5bf9\u98de\u901f\u53d1\u5c55\u7684\u6280\u672f\uff0c\u6211\u4eec\u4e5f\u5fc5\u987b\u6b63\u89c6\u968f\u4e4b\u800c\u6765\u7684\u4f26\u7406\u98ce\u9669\u4e0e\u672a\u6765\u8def\u5f84\u7684\u6311\u6218\u3002"
