            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4e8c\u96f6\u4e00\u516b\u5e74 BERT \u6a21\u578b\u6539\u53d8\u4e86\u81ea\u7136\u8bed\u8a00\u5904\u7406\u7684\u6280\u672f\u8303\u5f0f\uff0c\u6ce8\u610f\u529b\u673a\u5236\u4f7f\u6a21\u578b\u80fd\u591f\u6355\u6349\u957f\u8ddd\u79bb\u6587\u672c\u4f9d\u8d56\u5173\u7cfb\u7279\u5f81\u3002\u9884\u8bad\u7ec3\u52a0\u5fae\u8c03\u6a21\u5f0f\u663e\u8457\u964d\u4f4e\u4e86\u4e0b\u6e38\u4efb\u52a1\u7684\u6570\u636e\u9700\u6c42\uff0c\u8ba9\u8bed\u8a00\u7406\u89e3\u80fd\u529b\u5f97\u5230\u4e86\u8d28\u7684\u98de\u8dc3\u3002"
                },
                {
