            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u4f01\u4e1a\u5e94\u5236\u5b9a\u660e\u786e\u7684\u4eba\u5de5\u667a\u80fd\u6218\u7565\u4ee5\u628a\u63e1\u6570\u5b57\u5316\u8f6c\u578b\u673a\u9047\uff0c\u4e2a\u4eba\u9700\u6301\u7eed\u5b66\u4e60\u65b0\u6280\u672f\u4ee5\u9002\u5e94\u4eba\u673a\u534f\u4f5c\u7684\u65b0\u578b\u5de5\u4f5c\u6a21\u5f0f\u3002\u653f\u5e9c\u76d1\u7ba1\u653f\u7b56\u9700\u5e73\u8861\u6280\u672f\u521b\u65b0\u53d1\u5c55\u4e0e\u793e\u4f1a\u5b89\u5168\u4e4b\u95f4\u7684\u5173\u7cfb\uff0c\u5171\u540c\u6784\u5efa\u5065\u5eb7\u7684 AI \u751f\u6001\u3002"
                },
                {
                    "type": "bullet_list",
                    "items": [
