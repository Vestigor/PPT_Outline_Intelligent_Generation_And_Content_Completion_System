            "content_blocks": [
                {
                    "type": "paragraph",
                    "text": "\u533b\u7597\u5f71\u50cf\u5206\u6790\u8f85\u52a9\u533b\u751f\u63d0\u9ad8\u75be\u75c5\u8bca\u65ad\u7684\u51c6\u786e\u7387\u4e0e\u6548\u7387\uff0c\u81ea\u52a8\u9a7e\u9a76\u6280\u672f\u6b63\u5728\u9010\u6b65\u5b8c\u5584\u5e76\u8fdb\u5165\u5546\u4e1a\u5316\u8bd5\u70b9\u8fd0\u8425\u9636\u6bb5\u3002\u667a\u80fd\u5236\u9020\u901a\u8fc7\u9884\u6d4b\u6027\u7ef4\u62a4\u964d\u4f4e\u5de5\u5382\u8bbe\u5907\u505c\u673a\u5e26\u6765\u7684\u635f\u5931\uff0cAI \u6b63\u5728\u4ece\u5b9e\u9a8c\u5ba4\u8d70\u5411\u5b9e\u4f53\u7ecf\u6d4e\u3002"
