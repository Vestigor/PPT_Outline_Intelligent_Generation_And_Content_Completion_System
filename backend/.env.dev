# Local development defaults. Do not put real production credentials in this file.
# Create backend/.env for private overrides; .env takes precedence over .env.dev.

# Application
APP_NAME=PPT Intelligent Generation System
APP_VERSION=1.0.0
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://127.0.0.1:3001"]

# PostgreSQL exposed by docker-compose.dev.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ppt_system
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ppt_system
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# Redis exposed by docker-compose.dev.yml
REDIS_PASSWORD=123456
REDIS_URL=redis://:123456@localhost:6379/0
REDIS_ENCODING=utf-8
REDIS_DECODE_RESPONSES=true
REDIS_MAX_CONNECTIONS=50
REDIS_HEALTH_CHECK_INTERVAL=30

# Local-only JWT secret. Production must use a new random value.
SECRET_KEY=local-development-secret-key-not-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=180
REFRESH_TOKEN_EXPIRE_DAYS=7

# MinIO exposed by docker-compose.dev.yml
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
OSS_ENDPOINT=http://localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET_NAME=ppt-files
OSS_REGION=us-east-1
OSS_MAX_POOL_CONNECTIONS=50
OSS_MAX_ATTEMPTS=3

# LLM / embedding / RAG
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_STREAM_TIMEOUT=120
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
DASHSCOPE_API_KEY=
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
SEARCH_MAX_RESULTS=10

# Uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=["pdf","docx","md","txt"]

# Optional in local development. Fill these in backend/.env to test email features.
SMTP_HOST=smtp.yeah.net
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM_NAME=PPT 智能生成系统
EMAIL_CODE_TTL_SECONDS=600

# Password policy and middleware
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=16
SLOW_REQUEST_THRESHOLD_MS=2000
GZIP_MINIMUM_SIZE=1024
