{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PPT 幻灯片内容 Schema",
  "description": "完整的演示文稿幻灯片数据结构，便于前端渲染和后端导出",
  "type": "object",
  "required": ["presentation_title", "total_slides", "slides"],
  "additionalProperties": false,
  "properties": {
    "presentation_title": {
      "type": "string",
      "description": "演示文稿总标题"
    },
    "total_slides": {
      "type": "integer",
      "minimum": 1,
      "description": "幻灯片总数"
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "description": "幻灯片列表",
      "items": {
        "type": "object",
        "required": ["slide_number", "slide_type", "title"],
        "additionalProperties": false,
        "properties": {
          "slide_number": {
            "type": "integer",
            "minimum": 1,
            "description": "幻灯片编号（从 1 开始）"
          },
          "slide_type": {
            "type": "string",
            "enum": ["cover", "toc", "chapter_divider", "content", "ending"],
            "description": "幻灯片类型"
          },
          "title": {
            "type": "string",
            "description": "幻灯片标题"
          },
          "subtitle": {
            "type": ["string", "null"],
            "description": "副标题（cover 类型使用）"
          },
          "chapter_number": {
            "type": ["integer", "null"],
            "description": "章节编号（chapter_divider 类型使用）"
          },
          "chapter_title": {
            "type": ["string", "null"],
            "description": "所属章节标题（content 类型使用）"
          },
          "chapters": {
            "type": ["array", "null"],
            "items": { "type": "string" },
            "description": "章节列表（toc 类型使用）"
          },
          "content_blocks": {
            "type": ["array", "null"],
            "description": "内容块列表（content 类型使用）。文本中可嵌入 [N] 形式的引用编号，对应 references[].ref_number。",
            "items": {
              "type": "object",
              "required": ["type"],
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["bullet_list", "paragraph", "numbered_list", "quote"],
                  "description": "内容块类型"
                },
                "items": {
                  "type": ["array", "null"],
                  "items": { "type": "string" },
                  "description": "列表项（bullet_list / numbered_list 使用）；元素中可含 [N] 引用标记"
                },
                "text": {
                  "type": ["string", "null"],
                  "description": "段落文本（paragraph / quote 使用）；可含 [N] 引用标记"
                }
              }
            }
          },
          "speaker_notes": {
            "type": ["string", "null"],
            "description": "演讲者备注；可含 [N] 引用标记"
          },
          "references": {
            "type": ["array", "null"],
            "description": "本页参考文献清单（页内独立编号，从 1 开始）。无引用则为空数组。",
            "items": {
              "type": "object",
              "required": ["ref_number", "source_type", "source", "citation_style"],
              "additionalProperties": false,
              "properties": {
                "ref_number": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "页内 1-based 引用编号；正文 [N] 标记需对应此字段"
                },
                "source_type": {
                  "type": "string",
                  "enum": ["report", "rag", "web"],
                  "description": "report=用户上传报告；rag=知识库文档；web=网络搜索"
                },
                "source": {
                  "type": "string",
                  "minLength": 1,
                  "description": "report/rag 填文档名（含扩展名）；web 填完整 URL"
                },
                "citation_style": {
                  "type": "string",
                  "enum": ["direct", "paraphrase", "summary", "data"],
                  "description": "direct=直接引用原文；paraphrase=改写表达；summary=概括要点；data=引用数据/数字"
                },
                "snippet": {
                  "type": ["string", "null"],
                  "maxLength": 300,
                  "description": "被引用的原文节选（≤300字），便于溯源；可空"
                }
              }
            }
          }
        }
      }
    }
  }
}
