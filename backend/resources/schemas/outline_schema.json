{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PPT 叙事大纲 Schema",
  "description": "PPT 叙事骨架。每页只描述方向意图与必须覆盖的关键要素，不写最终展示文案——展示文案由 slide_generate 阶段生成。",
  "type": "object",
  "required": ["topic", "chapters"],
  "additionalProperties": false,
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "PPT 总主题"
    },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "description": "章节列表",
      "items": {
        "type": "object",
        "required": ["title", "summary", "slides"],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256,
            "description": "章节标题"
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200,
            "description": "本章核心论点或要回答的问题，1 句话"
          },
          "slides": {
            "type": "array",
            "minItems": 1,
            "maxItems": 20,
            "description": "页列表",
            "items": {
              "type": "object",
              "required": ["title", "slide_intent", "must_cover", "expected_takeaway"],
              "additionalProperties": false,
              "properties": {
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 256,
                  "description": "幻灯片标题"
                },
                "slide_intent": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200,
                  "description": "1 句话说清楚本页要让观众理解什么、为什么需要它"
                },
                "must_cover": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 8,
                  "description": "本页必须覆盖的关键概念/数据/年份/人物/案例（短语形式，每条 ≤ 30 字）。这是 slide_generate 阶段必须落地到正文的硬约束。",
                  "items": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 30
                  }
                },
                "expected_takeaway": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200,
                  "description": "观众听完本页应记住的 1 句话核心结论"
                }
              }
            }
          }
        }
      }
    }
  }
}
